<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Driver Tree View -->
    <record id="view_transitops_driver_tree" model="ir.ui.view">
        <field name="name">transitops.driver.tree</field>
        <field name="model">transitops.driver</field>
        <field name="arch" type="xml">
            <tree string="Drivers">
                <field name="name"/>
                <field name="contact_number"/>
                <field name="license_number"/>
                <field name="license_category"/>
                <field name="license_expiry_date"/>
                <field name="safety_score" avg="Average Safety Score"/>
                <field name="status" widget="badge" decoration-success="status == 'available'" decoration-info="status == 'on_trip'" decoration-warning="status == 'off_duty'" decoration-danger="status == 'suspended'"/>
            </tree>
        </field>
    </record>

    <!-- Driver Form View -->
    <record id="view_transitops_driver_form" model="ir.ui.view">
        <field name="name">transitops.driver.form</field>
        <field name="model">transitops.driver</field>
        <field name="arch" type="xml">
            <form string="Driver">
                <header>
                    <button name="action_set_available" string="Set Available" type="object" class="oe_highlight" invisible="status == 'available'"/>
                    <button name="action_set_on_trip" string="Set On Trip" type="object" invisible="status == 'on_trip'"/>
                    <button name="action_set_off_duty" string="Set Off Duty" type="object" invisible="status == 'off_duty'"/>
                    <button name="action_set_suspended" string="Suspend Driver" type="object" class="btn-danger" invisible="status == 'suspended'"/>
                    <field name="status" widget="statusbar" statusbar_visible="available,on_trip,off_duty,suspended"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Driver Full Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="License Details">
                            <field name="license_number"/>
                            <field name="license_category"/>
                            <field name="license_expiry_date"/>
                        </group>
                        <group string="Contact &amp; Performance">
                            <field name="contact_number"/>
                            <field name="safety_score"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Driver Search View -->
    <record id="view_transitops_driver_search" model="ir.ui.view">
        <field name="name">transitops.driver.search</field>
        <field name="model">transitops.driver</field>
        <field name="arch" type="xml">
            <search string="Search Drivers">
                <field name="name"/>
                <field name="license_number"/>
                <filter string="Available" name="available" domain="[('status', '=', 'available')]"/>
                <filter string="On Trip" name="on_trip" domain="[('status', '=', 'on_trip')]"/>
                <filter string="Off Duty" name="off_duty" domain="[('status', '=', 'off_duty')]"/>
                <filter string="Suspended" name="suspended" domain="[('status', '=', 'suspended')]"/>
                <group expand="0" string="Group By">
                    <filter string="License Category" name="group_by_license_category" context="{'group_by': 'license_category'}"/>
                    <filter string="Status" name="group_by_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Driver Action -->
    <record id="action_transitops_driver" model="actions.act_window">
        <field name="name">Drivers</field>
        <field name="res_model">transitops.driver</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_transitops_driver_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register a new driver!
            </p>
        </field>
    </record>
</odoo>
