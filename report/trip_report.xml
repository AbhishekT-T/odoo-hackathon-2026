<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Trip Report Action Definition -->
    <record id="action_report_trip_details" model="ir.actions.report">
        <field name="name">Trip Details</field>
        <field name="model">transitops.trip</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">transitops.report_trip_details_template</field>
        <field name="report_file">transitops.report_trip_details_template</field>
        <field name="binding_model_id" ref="model_transitops_trip"/>
        <field name="binding_type">report</field>
    </record>

    <!-- QWeb PDF Report Template -->
    <template id="report_trip_details_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="oe_structure"/>
                        <h2>Trip Details: <span t-field="doc.name"/></h2>
                        <div class="row mt32 mb32">
                            <div class="col-6">
                                <strong>Source:</strong> <span t-field="doc.source"/><br/>
                                <strong>Destination:</strong> <span t-field="doc.destination"/><br/>
                                <strong>Distance:</strong> <span t-field="doc.planned_distance"/> km<br/>
                            </div>
                            <div class="col-6">
                                <strong>Vehicle:</strong> <span t-field="doc.vehicle_id.registration_number"/> (<span t-field="doc.vehicle_id.type"/>)<br/>
                                <strong>Driver:</strong> <span t-field="doc.driver_id.name"/><br/>
                                <strong>Cargo Weight:</strong> <span t-field="doc.cargo_weight"/> kg<br/>
                                <strong>Status:</strong> <span t-field="doc.status"/><br/>
                            </div>
                        </div>
                        <div class="oe_structure"/>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
