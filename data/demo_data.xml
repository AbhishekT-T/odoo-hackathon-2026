<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Vehicles -->
        <record id="vehicle_1" model="transitops.vehicle">
            <field name="registration_number">TX-909-OP</field>
            <field name="name">Ford Transit Heavy Van</field>
            <field name="type">Heavy Duty Truck</field>
            <field name="max_load_capacity">15000</field>
            <field name="odometer">45200</field>
            <field name="acquisition_cost">85000</field>
            <field name="status">available</field>
        </record>

        <record id="vehicle_2" model="transitops.vehicle">
            <field name="registration_number">TX-404-SH</field>
            <field name="name">Mercedes Sprinter Cargo</field>
            <field name="type">Delivery Van</field>
            <field name="max_load_capacity">3500</field>
            <field name="odometer">12000</field>
            <field name="acquisition_cost">35000</field>
            <field name="status">in_shop</field>
        </record>

        <record id="vehicle_3" model="transitops.vehicle">
            <field name="registration_number">TX-707-VN</field>
            <field name="name">Van-05</field>
            <field name="type">Delivery Van</field>
            <field name="max_load_capacity">500</field>
            <field name="odometer">1000</field>
            <field name="acquisition_cost">25000</field>
            <field name="status">available</field>
        </record>

        <!-- Drivers -->
        <record id="driver_1" model="transitops.driver">
            <field name="name">Alice Smith</field>
            <field name="license_number">DL-88271A</field>
            <field name="license_category">Class A CDL</field>
            <field name="license_expiry_date" eval="(datetime.now() + relativedelta(years=2)).strftime('%Y-%m-%d')"/>
            <field name="contact_number">+1 555-0199</field>
            <field name="safety_score">98.5</field>
            <field name="status">available</field>
        </record>

        <record id="driver_2" model="transitops.driver">
            <field name="name">Bob Miller</field>
            <field name="license_number">DL-11029B</field>
            <field name="license_category">Class B CDL</field>
            <field name="license_expiry_date" eval="(datetime.now() + relativedelta(months=6)).strftime('%Y-%m-%d')"/>
            <field name="contact_number">+1 555-0144</field>
            <field name="safety_score">72.0</field>
            <field name="status">suspended</field>
        </record>

        <record id="driver_3" model="transitops.driver">
            <field name="name">Alex</field>
            <field name="license_number">DL-99999X</field>
            <field name="license_category">Class B CDL</field>
            <field name="license_expiry_date" eval="(datetime.now() + relativedelta(years=1)).strftime('%Y-%m-%d')"/>
            <field name="contact_number">+1 555-0177</field>
            <field name="safety_score">95.0</field>
            <field name="status">available</field>
        </record>

        <!-- Sequences -->
        <record id="seq_transitops_trip" model="ir.sequence">
            <field name="name">Trip Reference Sequence</field>
            <field name="code">transitops.trip</field>
            <field name="prefix">TRIP/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_transitops_maintenance" model="ir.sequence">
            <field name="name">Maintenance Reference Sequence</field>
            <field name="code">transitops.maintenance</field>
            <field name="prefix">MAINT/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Trips -->
        <record id="trip_1" model="transitops.trip">
            <field name="source">Chicago Depot</field>
            <field name="destination">New York Hub</field>
            <field name="vehicle_id" ref="vehicle_1"/>
            <field name="driver_id" ref="driver_1"/>
            <field name="cargo_weight">12500</field>
            <field name="planned_distance">1270</field>
            <field name="revenue">3200.0</field>
            <field name="status">draft</field>
        </record>

        <!-- Maintenance Logs -->
        <record id="maint_1" model="transitops.maintenance">
            <field name="vehicle_id" ref="vehicle_2"/>
            <field name="description">Brake pad replacement and engine check.</field>
            <field name="cost">450.0</field>
            <field name="status">active</field>
        </record>

        <!-- Fuel Logs -->
        <record id="fuel_1" model="transitops.fuel.expense">
            <field name="vehicle_id" ref="vehicle_1"/>
            <field name="liters">320.0</field>
            <field name="cost">640.0</field>
            <field name="date" eval="datetime.now().strftime('%Y-%m-%d')"/>
            <field name="expense_type">diesel</field>
        </record>
    </data>
</odoo>
